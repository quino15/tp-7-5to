#include <iostream>
using namespace std;
class Alumno
{
    private:
        char nombre[40];
        int edad;
    public:
        void inicializar();
        void imprimir();
        void esMayorEdad();
};

void Alumno::inicializar()
{
    cout <<"Ingrese nombre:";
    cin.getline(nombre,40);
    cout <<"Ingrese edad:";
    cin >>edad;
}
void Alumno::imprimir()
{
    cout <<"Nombre:";
    cout <<nombre;
    cout <<"\n";
    cout <<"Edad:";
    cout <<edad;
    cout <<"\n";
}
void Alumno::esMayorEdad()
{
    if (edad>=18)
    {
        cout <<"Es mayor de edad.";
    }
    else
    {
        cout <<"No es mayor de edad.";
    }
    cin.get();
    cin.get();
}
